# ── API Keys ──────────────────────────────────────────────────────────────────
# Alpaca (free paper trading account → https://alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# NewsAPI (free tier → https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# OpenAI (for agent debate) → https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Google Gemini (alternative for free live AI) → https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://postgres:password@db:5432/marketpulse

# ── App Config ────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# Data source: "yfinance" (default, real prices), "mock" (simulated), "live" (Alpaca real-time)
DATA_MODE=yfinance

# CORS allowed origins (comma-separated for production domains)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# ── Authentication ────────────────────────────────────────────────────────────
# JWT_SECRET: REQUIRED for production. Used to sign JWT tokens for WebSocket auth.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If empty, a random secret is generated at startup (safe for dev, NOT for prod).
JWT_SECRET=

# API_KEY: shared API key for protecting REST endpoints.
# If empty, REST endpoints are unprotected (dev mode).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────────
# SENTRY_DSN: error tracking DSN from https://sentry.io
# If empty, Sentry is disabled (no-op).
SENTRY_DSN=

# ── Client ────────────────────────────────────────────────────────────────────
# Public endpoints for Next.js build:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
